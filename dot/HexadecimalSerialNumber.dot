digraph HexSerial {
  ascii [shape=none, margin=0, label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
    <TR><TD COLSPAN="9">ASCII</TD></TR>
    <TR><TD>0</TD><TD>1</TD><TD>2</TD><TD>3</TD><TD>4</TD><TD>5</TD><TD>6</TD><TD>7</TD><TD>8</TD></TR>
    <TR><TD PORT="Y1" COLSPAN="2">YY</TD><TD PORT="M1" COLSPAN="2">WW</TD><TD PORT="N1" COLSPAN="5">NNNNN</TD></TR>
    </TABLE>>];

  hexnum [shape=none, margin=0, label=<
    <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4">
    <TR><TD COLSPAN="9">Number</TD></TR>
    <TR><TD>0</TD><TD>1</TD><TD>2</TD><TD>3</TD></TR>
    <TR><TD PORT="YYp1">YY'</TD><TD PORT="MMp1">WW'</TD><TD PORT="NNp1" COLSPAN="2">NNNN'</TD></TR>
    </TABLE>>];

  ascii:Y1->hexnum:YYp1:w [label="toNum()"]
  ascii:M1->hexnum:MMp1:n [label="toNum()"]
  ascii:N1->hexnum:NNp1:e [label="toNum()"]
}